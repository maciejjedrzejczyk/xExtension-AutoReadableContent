<div class="post">
  <h2>Auto Readable Content</h2>
  <p>Automatically fetches and extracts readable article content for feeds that provide empty or minimal content (e.g. Hacker News, Lobsters).</p>

  <form action="<?= _url('extension', 'configure', 'e', urlencode($this->getName())) ?>" method="post">
    <input type="hidden" name="_csrf" value="<?= FreshRSS_Auth::csrfToken() ?>" />

    <fieldset>
      <legend>Settings</legend>

      <div class="form-group">
        <label for="threshold">Content threshold (characters):</label>
        <input type="number" name="threshold" id="threshold" value="<?= (int)$threshold ?>" min="0" max="5000" />
        <p class="help">Articles with fewer characters of text content than this will trigger auto-fetch. Default: 200. Set to 0 to fetch for all articles.</p>
      </div>

      <div class="form-group">
        <label for="timeout">Fetch timeout (seconds):</label>
        <input type="number" name="timeout" id="timeout" value="<?= (int)$timeout ?>" min="5" max="60" />
